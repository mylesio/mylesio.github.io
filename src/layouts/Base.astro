---
interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}
const { title, description = "Myles Liu — frontend engineer, AI agent practitioner.", noindex = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const isHome = Astro.url.pathname === '/';
const path = Astro.url.pathname;
// Divider on: /about, /notes/<slug>, /stream (and /stream/)
const showDivider = path === '/about' || path === '/about/'
  || (path.startsWith('/notes/') && path.replace(/\/$/, '') !== '/notes')
  || path === '/stream' || path === '/stream/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{isHome ? 'mylesio' : `${title} — mylesio`}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500&display=swap" rel="stylesheet" />
    <script src="/favicon-anim.js" defer></script>
    <script src="/dino.js" defer></script>
    <style>
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Light.otf') format('opentype');
        font-weight: 300;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-LightItalic.otf') format('opentype');
        font-weight: 300;
        font-style: italic;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Book.otf') format('opentype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-BookItalic.otf') format('opentype');
        font-weight: 400;
        font-style: italic;
        font-display: swap;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:          #f5f2ec;   /* warm off-white / parchment */
        --surface:     #eeeae2;   /* slightly deeper warm white for surfaces */
        --border:      #ddd8ce;   /* warm tan border */
        --text:        #1a1917;   /* near-black with warm undertone */
        --muted:       #6b6860;   /* warm gray, ~4.8:1 on --bg */
        --label:       #9c9890;   /* uppercase labels, decorative only */
        --dim:         #c8c4ba;   /* non-text only: rules, decorative */
        --accent:      #0284c7;   /* deeper sky blue — readable on light bg */
        --accent-mid:  #0ea5e9;   /* mid blue */
        --accent-dim:  #7dd3fc;   /* light blue for hairlines on light bg */
        --accent-wash: #e0eef7;   /* very subtle blue tint for borders/surfaces */
        --green:       #16a34a;   /* semantic green: active / live status */
        --green-dim:   #dcfce7;   /* green wash for tag bg */
        --amber:       #b45309;   /* semantic amber: warning / archived */
        --mono:        'OperatorMonoLig', 'Operator Mono', 'Fira Code', monospace;
        --col:         640px;
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      }

      html { font-size: 15px; }

      body {
        background: transparent;
        color: var(--text);
        font-family: var(--mono);
        font-size: 1rem;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      html { background: var(--bg); }
      body { background: transparent; }

      /* html bg color fills behind fixed navbar */

      ::selection { background: var(--accent); color: #111112; }

      /* ─── Links ──────────────────────────────────── */
      a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
        transition: color 0.18s var(--ease-out-expo),
                    text-decoration-color 0.18s var(--ease-out-expo);
      }
      a:hover {
        color: var(--accent);
        text-decoration-color: var(--accent);
      }

      a.nav-link {
        border-bottom: none;
        color: var(--muted);
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        transition: color 0.18s var(--ease-out-expo);
      }
      a.nav-link:hover { color: var(--text); }
      a.nav-link.active { color: var(--accent); }

      /* ─── Layout ─────────────────────────────────── */
      .page-wrap {
        max-width: var(--col);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* ─── Dino stage: fixed, independent GPU layer, below navbar ── */
      #dino-stage {
        position: fixed;
        top: 0; left: 0;
        width: 100%;
        height: 48px;           /* clipped to navbar height when idle */
        overflow: hidden;
        z-index: 60;            /* above navbar z:50 so idle dino is visible */
        pointer-events: none;   /* stage itself: no events */
        background: #f5f2ec;
        transition: height 0.4s ease-out;
      }
      /* hitArea inside dino-stage needs pointer events despite parent none */
      #dino-hit-area {
        pointer-events: auto !important;
      }
      #dino-stage.expanded {
        height: 170px;
      }

      #dino-canvas {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        height: 170px;
        display: block;
        image-rendering: pixelated;
        image-rendering: crisp-edges;
      }

      /* ─── Sticky navbar: pure nav, no canvas ────────── */
      .site-header {
        position: sticky;
        top: 0;
        width: 100%;
        height: 48px;
        background: transparent;  /* dino-stage provides bg */
        z-index: 80;              /* above dino-stage z:60 */
        pointer-events: none;     /* pass clicks through to dino-stage hitArea */
      }
      /* navbar inner: clickable, but background transparent so dino shows */
      .site-header header {
        pointer-events: auto;
      }

      /* ─── Liquid Glass navbar bar ────────────────────── */
      header {
        position: absolute;
        top: 0; left: 0; right: 0;
        z-index: 10;
        background: transparent;  /* dino-stage #f5f2ec shows through */
        border-bottom: 1px solid rgba(200, 195, 185, 0.25);
        box-shadow: 0 1px 0 rgba(255,255,255,0.5) inset;
      }

      .nav-inner {
        max-width: var(--col);
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .nav-inner nav {
        flex: 1;          /* nav 撑满中间，lang-toggle 自然靠右 */
        display: flex;
        gap: 1.5rem;
      }

      .logo {
        font-size: 0.9rem;
        font-weight: 400;
        color: #333;
        border-bottom: none;
        letter-spacing: 0.02em;
        transition: color 0.18s var(--ease-out-expo);
        text-decoration: none;
      }
      .logo:hover { color: var(--accent); text-decoration: none; }

      /* nav flex handled by .nav-inner nav above */

      header a.nav-link {
        color: #888;
        text-decoration: none;
        font-size: 0.85rem;
        transition: color 0.15s;
      }
      header a.nav-link:hover { color: #333; }
      header a.nav-link.active { color: var(--accent); font-weight: 500; }

      @media (max-width: 480px) {
        header { gap: 1rem; padding-left: 1rem; padding-right: 1rem; }
      }

      main {
        padding: 1rem 0 5rem;
      }

      footer {
        padding: 1.5rem 0 2.5rem;
        border-top: 1px solid var(--accent-wash);
        display: flex;
        justify-content: space-between;
        font-size: 0.78rem;
        color: var(--muted);
      }
      footer a { color: var(--muted); border-color: transparent; }
      footer a:hover { color: var(--text); border-color: transparent; }

      /* ─── Lang divider ───────────────────────────── */
      /* The split-view lives inside .lang-stage which wraps <main>.
         EN layer is always visible; ZH layer sits on top, clipped from the right.
         The divider SVG line + handle floats at the split position.            */

      .lang-stage {
        position: relative;
        overflow: hidden; /* clips the diagonal line at stage boundaries */
      }
      .lang-stage--plain {
        overflow: visible; /* no divider, no need to clip */
      }
      #lang-en-layer {
        position: relative;
        will-change: clip-path, transform;
        transform: translateZ(0); /* promote to independent GPU layer */
        background: var(--bg); /* cover ZH layer on the left side */
      }
      /* ZH layer sits BELOW EN layer; EN clips left side exposing ZH on right */
      .lang-zh-layer {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        min-height: 100%;
        /* no clip-path needed — ZH is always fully rendered, EN covers it on the left */
        will-change: transform;
        transform: translateZ(0); /* promote to independent GPU layer */
      }

      /* EN / 中 labels at top corners */
      .lang-label-en,
      .lang-label-zh {
        position: absolute;
        top: 1.5rem;
        font-size: 0.6rem;
        letter-spacing: 0.12em;
        color: #d946a8;
        pointer-events: none;
        user-select: none;
        z-index: 5;
        opacity: 0.6;
        text-transform: uppercase;
      }
      /* initial positions overridden by JS */
      .lang-label-en { left: 1rem; }
      .lang-label-zh { left: 60%; }
      .lang-label-en, .lang-label-zh {
        transition: opacity 0.2s;
      }

      /* Frosted glass wings outside the content stage */
      #lang-wing-l, #lang-wing-r {
        position: fixed;
        top: 0;
        height: 100vh;
        pointer-events: none;
        z-index: 11; /* above SVG line (z-index:10) */
        /* No backdrop-filter — too expensive (forces full-page GPU blur every frame) */
        /* Use solid background color instead */
        background: var(--bg);
      }
      #lang-wing-l {
        left: 0;
        /* inner edge fades into content */
        -webkit-mask-image: linear-gradient(to right, black 60%, transparent 100%);
        mask-image: linear-gradient(to right, black 60%, transparent 100%);
      }
      #lang-wing-r {
        right: 0;
        -webkit-mask-image: linear-gradient(to left, black 60%, transparent 100%);
        mask-image: linear-gradient(to left, black 60%, transparent 100%);
      }

      /* ZH layer font + match main padding so content starts at same y as EN */
      .lang-zh-layer {
        font-family: 'Noto Serif SC', 'Source Han Serif CN', 'STSong',
                     Georgia, serif;
        letter-spacing: 0.03em;
        padding: 1rem 0 5rem;
      }

      /* .lang-section display/padding is set inline by wrapSections() JS so it
         works on dynamically-created elements (no Astro scope hash needed). */

      /* Divider line SVG */
      #lang-divider {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        pointer-events: none;
        z-index: 10;
        overflow: visible;
      }
      #lang-divider line {
        stroke: #d946a8;
        stroke-width: 1.5;
        opacity: 0.85;
      }


      /* ─── Mobile ─────────────────────────────────── */
      @media (max-width: 480px) {
        html { font-size: 14px; }

        .page-wrap { padding: 0 1rem; }

        header {
          padding: 1rem 0;
          gap: 1rem;
          flex-wrap: wrap;
        }

        footer {
          flex-direction: column;
          gap: 0.4rem;
        }


      }

      /* ─── Page entrance ──────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .reveal {
        opacity: 0;
        animation: fadeUp 0.55s var(--ease-out-expo) forwards;
      }
      .reveal-1 { animation-delay: 0.05s; }
      .reveal-2 { animation-delay: 0.15s; }
      .reveal-3 { animation-delay: 0.25s; }
      .reveal-4 { animation-delay: 0.35s; }

      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; animation: none; }
      }
    </style>
  </head>
  <body>
    <!-- dino stage: fixed, independent of navbar, z-index below navbar -->
    <div id="dino-stage">
      <canvas id="dino-canvas" title="Click to play"></canvas>
    </div>
    <!-- sticky navbar: always on top, no canvas inside -->
    <div class="site-header">
      <header>
        <div class="nav-inner">
          <span id="dino-anchor" style="display:inline-block;width:0;height:0;"></span>
          <a class="logo reveal reveal-1" href="/">mylesio</a>
          <nav class="reveal reveal-1">
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/notes') }]} href="/notes" data-en="notes" data-zh="笔记">notes</a>
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/projects') }]} href="/projects" data-en="projects" data-zh="项目">projects</a>
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/about') }]} href="/about" data-en="about" data-zh="关于">about</a>
          </nav>
        </div>
      </header>
    </div>
    <div class="page-wrap">
      <!-- lang-stage: wraps main, hosts the split divider (divider only on note/about pages) -->
      <div class:list={["lang-stage", { "lang-stage--plain": !showDivider }]} id="lang-stage">
        {showDivider && (
          <div class="lang-zh-layer" id="lang-zh-layer" aria-hidden="true"></div>
        )}

        <main id="lang-en-layer">
          <slot />
        </main>

        {showDivider && (
          <>
            <svg id="lang-divider" aria-hidden="true"
                 style="position:fixed;top:0;left:0;width:100vw;height:100vh;overflow:visible;pointer-events:none;z-index:10;">
              <line id="lang-divider-solid" stroke="#d946a8" stroke-width="1.5" opacity="0.85"/>
              <line id="lang-divider-dash-l" stroke="#d946a8" stroke-width="1.5" opacity="0.4" stroke-dasharray="4 6"/>
              <line id="lang-divider-dash-r" stroke="#d946a8" stroke-width="1.5" opacity="0.4" stroke-dasharray="4 6"/>
            </svg>
            <span class="lang-label-en" id="lang-label-en">EN</span>
            <span class="lang-label-zh" id="lang-label-zh">中</span>
          </>
        )}
      </div>

      {showDivider && (
        <>
          <div id="lang-wing-l" aria-hidden="true"></div>
          <div id="lang-wing-r" aria-hidden="true"></div>
        </>
      )}

      <footer>
        <span>Myles Liu</span>
        <span><a href="/llms.txt">llms.txt</a></span>
      </footer>
    </div>
    <script>
      // ── Language split-view divider ──────────────────────────────────────
      // Only initialize on pages with showDivider (about + notes slugs)
      (function () {
        function init() {
        if (!document.getElementById('lang-divider')) return; // not a divider page, exit immediately

        // Inject ZH content from template into ZH layer
        const tpl = document.getElementById('zh-content-tpl');
        const zhLayerInit = document.getElementById('lang-zh-layer');
        if (tpl && zhLayerInit && !zhLayerInit.dataset.injected) {
          zhLayerInit.dataset.injected = '1';
          zhLayerInit.appendChild(tpl.content.cloneNode(true));
        }

        // ── Section height alignment ─────────────────────────────────────
        // Wrap each prose child element into its own lang-section div SYNCHRONOUSLY
        // (before first paint) so there's no visible DOM restructure later.
        // One child = one section; EN and ZH sections are paired 1-to-1 for height alignment.
        // min-height is set after fonts load (async) to get accurate heights.
        let enSectionDivs = [];
        let zhSectionDivs = [];

        function wrapSections(prose) {
          const children = Array.from(prose.children);
          return children.map(child => {
            const wrap = document.createElement('div');
            wrap.className = 'lang-section';
            // display:flow-root creates BFC, preventing child margin collapse from
            // bleeding out and causing EN/ZH section tops to drift apart.
            // padding-bottom replaces child bottom-margin as the inter-section spacer
            // so spacing is font-independent and identical on both sides.
            wrap.style.cssText = 'display:flow-root;';
            const tag = child.tagName;
            if (tag === 'H2') {
              wrap.style.paddingTop = '1.75rem';
              wrap.style.paddingBottom = '0.5rem';
              child.style.margin = '0';
            } else if (tag === 'H3') {
              wrap.style.paddingTop = '1.25rem';
              wrap.style.paddingBottom = '0.25rem';
              child.style.margin = '0';
            } else {
              wrap.style.paddingBottom = '1.25rem';
              // strip child bottom margin to avoid double-spacing
              const cs = getComputedStyle(child);
              const mb = parseFloat(cs.marginBottom);
              if (mb > 0) child.style.marginBottom = '0';
            }
            prose.insertBefore(wrap, child);
            wrap.appendChild(child);
            return wrap;
          });
        }

        // Wrap immediately (sync) — no visual flash
        (function doWrap() {
          const enLayer0 = document.getElementById('lang-en-layer');
          const zhLayer0 = document.getElementById('lang-zh-layer');
          if (!enLayer0 || !zhLayer0) return;
          const enProse0 = enLayer0.querySelector('.prose');
          const zhProse0 = zhLayer0.querySelector('.prose');
          if (enProse0 && zhProse0 && enSectionDivs.length === 0) {
            enSectionDivs = wrapSections(enProse0);
            zhSectionDivs = wrapSections(zhProse0);
          } else if (!enProse0 && enSectionDivs.length === 0) {
            // Fallback for pages that already use .lang-section directly (e.g. /stream)
            enSectionDivs = Array.from(enLayer0.querySelectorAll('.lang-section'));
            zhSectionDivs = Array.from(zhLayer0.querySelectorAll('.lang-section'));
            console.log('[align] stream fallback: en=', enSectionDivs.length, 'zh=', zhSectionDivs.length);
          }
        })();

        function alignSections() {
          const enLayer2 = document.getElementById('lang-en-layer');
          const zhLayer2 = document.getElementById('lang-zh-layer');
          if (!enLayer2 || !zhLayer2) return;

          // Ensure sections are populated (fallback for stream-style pages)
          if (enSectionDivs.length === 0) {
            const enProse2 = enLayer2.querySelector('.prose');
            if (enProse2) {
              enSectionDivs = wrapSections(enProse2);
              zhSectionDivs = wrapSections(zhLayer2.querySelector('.prose'));
            } else {
              enSectionDivs = Array.from(enLayer2.querySelectorAll('.lang-section'));
              zhSectionDivs = Array.from(zhLayer2.querySelectorAll('.lang-section'));
            }
          }

          // Align post-header heights (title may wrap differently EN vs ZH)
          const enHeader = enLayer2.querySelector('.post-header');
          const zhHeader = zhLayer2.querySelector('.post-header');
          if (enHeader && zhHeader) {
            enHeader.style.minHeight = '';
            zhHeader.style.minHeight = '';
            void enLayer2.offsetHeight; // reflow
            const maxHdrH = Math.max(enHeader.getBoundingClientRect().height, zhHeader.getBoundingClientRect().height);
            enHeader.style.minHeight = maxHdrH + 'px';
            zhHeader.style.minHeight = maxHdrH + 'px';
          }

          // Re-measure and set min-heights on each pair
          const len = Math.min(enSectionDivs.length, zhSectionDivs.length);
          // Reset all minHeights first
          for (let i = 0; i < len; i++) {
            enSectionDivs[i].style.minHeight = '';
            zhSectionDivs[i].style.minHeight = '';
          }
          // Force reflow so offsetHeight reflects natural content height,
          // not the previously set minHeight value.
          void document.getElementById('lang-en-layer')?.offsetHeight;
          // Measure natural heights and align pairs.
          // Use getBoundingClientRect().height (sub-pixel float) instead of
          // offsetHeight (integer-truncated) to prevent cumulative drift on
          // long pages where ~0.1px/section adds up to visible misalignment.
          for (let i = 0; i < len; i++) {
            const enEl = enSectionDivs[i];
            const zhEl = zhSectionDivs[i];
            const enCs = getComputedStyle(enEl);
            const zhCs = getComputedStyle(zhEl);
            const enPad = parseFloat(enCs.paddingTop) + parseFloat(enCs.paddingBottom)
                        + parseFloat(enCs.borderTopWidth) + parseFloat(enCs.borderBottomWidth);
            const zhPad = parseFloat(zhCs.paddingTop) + parseFloat(zhCs.paddingBottom)
                        + parseFloat(zhCs.borderTopWidth) + parseFloat(zhCs.borderBottomWidth);
            const enContentH = enEl.getBoundingClientRect().height - enPad;
            const zhContentH = zhEl.getBoundingClientRect().height - zhPad;
            const maxContentH = Math.max(enContentH, zhContentH);
            // Set both sides to the same content height so total heights match
            enEl.style.minHeight = maxContentH + 'px';
            zhEl.style.minHeight = maxContentH + 'px';
          }
        }

        // Run once after fonts are ready and browser has completed first layout.
        // fonts.ready resolves after all fonts in the document are loaded,
        // then rAF ensures we're in the next paint frame (layout already done).
        // We also schedule a second pass 600ms later to catch late-loading CJK
        // web fonts (e.g. Noto Serif SC from Google Fonts) that may resolve
        // after fonts.ready (due to font subsetting / lazy loading).
        function scheduleAlign() {
          requestAnimationFrame(alignSections);
          setTimeout(() => requestAnimationFrame(alignSections), 600);
        }
        if (document.fonts) {
          document.fonts.ready.then(scheduleAlign);
        } else {
          scheduleAlign();
        }

        const SPLIT_KEY = 'lang-split-x';
        const stage   = document.getElementById('lang-stage');
        const enLayer = document.getElementById('lang-en-layer');
        const zhLayer = document.getElementById('lang-zh-layer');
        const svgEl   = document.getElementById('lang-divider');
        const divSolid = document.getElementById('lang-divider-solid');
        const divDashL = document.getElementById('lang-divider-dash-l');
        const divDashR = document.getElementById('lang-divider-dash-r');
        const wingL    = document.getElementById('lang-wing-l');
        const wingR    = document.getElementById('lang-wing-r');

        function updateWings() {
          const r = stage.getBoundingClientRect();
          const leftW  = Math.max(0, r.left);
          const rightW = Math.max(0, window.innerWidth - r.right);
          if (wingL) wingL.style.width = leftW  + 'px';
          if (wingR) wingR.style.width = rightW + 'px';
        }
        const labelEN = document.getElementById('lang-label-en');
        const labelZH = document.getElementById('lang-label-zh');
        if (!stage || !divSolid) return;

        const SKEW_DEG = 15; // ~75° from horizontal (nearly vertical)
        const SKEW_RAD = SKEW_DEG * Math.PI / 180;
        const HIT_DIST = 28;   // px from line to activate cursor
        // snap bounds computed dynamically in snapIfNeeded() based on off/SW

        // splitRatio: 0~1, based on VIEWPORT width
        // This means clientX / innerWidth = splitRatio at the mid-height of the line
        let splitRatio = 0.50;
        try {
          const s = parseFloat(localStorage.getItem(SPLIT_KEY));
          if (!isNaN(s)) splitRatio = s; // restore as-is, snap will fix if needed
        } catch(_) {}

        // ── Geometry: stage-local coords throughout ───────────────────────
        // ── Geometry ─────────────────────────────────────────────────────
        // SVG is position:fixed (100vw×100vh) → line coords are viewport (clientX/Y).
        // splitRatio = fraction of stage width; midX in stage-local → convert to viewport x.
        // Line direction: top-right → bottom-left (/ shape).

        function getGeom() {
          const VW  = window.innerWidth;
          const VH  = window.innerHeight;
          const SW  = stage.offsetWidth;
          const SH  = stage.offsetHeight;
          const off = Math.tan(SKEW_RAD) * VH / 2;
          // midX in viewport coords: stage left + splitRatio * stage width
          const rect  = stage.getBoundingClientRect();
          const midVX = rect.left + splitRatio * SW;
          // / direction: top = right, bottom = left
          const vx0 = midVX + off;  // viewport x at vy=0
          const vx1 = midVX - off;  // viewport x at vy=VH
          return { vx0, vx1, VW, VH, SW, SH, rect };
        }

                // ── Render ────────────────────────────────────────────────────────
        function render() {
          const { vx0, vx1, VH, SW, SH, rect } = getGeom();
          // lineXatVY inlined — avoids extra getBoundingClientRect calls
          function lineXatVY(vy) { return vx0 + (vx1 - vx0) * (vy / VH); }

          // Stage bounds in viewport coords
          const stageL = rect.left;
          const stageR = rect.left + SW;

          // Full line spans vy=0..VH in viewport coords
          // Find where line crosses stageL and stageR (viewport y)
          // lineXatVY(vy) = vx0 + (vx1-vx0)*(vy/VH)
          // Invert: vy = (x - vx0) / (vx1-vx0) * VH
          const slope = (vx1 - vx0); // dx over full VH
          function vyAtVX(vx) {
            if (Math.abs(slope) < 0.001) return null; // nearly vertical, no crossing
            return ((vx - vx0) / slope) * VH;
          }

          const vyL = vyAtVX(stageL); // vy where line crosses stage left edge
          const vyR = vyAtVX(stageR); // vy where line crosses stage right edge

          // Determine entry/exit vy within viewport [0, VH]
          // Line goes / direction: top=right, bottom=left → crosses stageR at top, stageL at bottom
          const vyEnter = Math.max(0, Math.min(VH, Math.min(vyL ?? 0,  vyR ?? 0)));
          const vyExit  = Math.max(0, Math.min(VH, Math.max(vyL ?? VH, vyR ?? VH)));

          // Helper: set or hide a line element
          function setLine(el, x1, y1, x2, y2, show) {
            if (show) {
              el.setAttribute('x1', x1.toFixed(1)); el.setAttribute('y1', y1.toFixed(1));
              el.setAttribute('x2', x2.toFixed(1)); el.setAttribute('y2', y2.toFixed(1));
              el.setAttribute('visibility', 'visible');
            } else {
              el.setAttribute('visibility', 'hidden');
            }
          }

          // Solid segment: within stage (vyEnter → vyExit)
          const sxEnter = lineXatVY(vyEnter);
          const sxExit  = lineXatVY(vyExit);
          setLine(divSolid, sxEnter, vyEnter, sxExit, vyExit, vyEnter < vyExit);

          // Dashed top segment: above stage entry (0 → vyEnter)
          setLine(divDashL, vx0, 0, sxEnter, vyEnter, vyEnter > 0);

          // Dashed bottom segment: below stage exit (vyExit → VH)
          setLine(divDashR, sxExit, vyExit, vx1, VH, vyExit < VH);

          // clip-path in stage %
          const sxTop = lineXatVY(rect.top)      - rect.left;
          const sxBot = lineXatVY(rect.top + SH) - rect.left;
          const p0 = ((sxTop / SW) * 100).toFixed(3) + '%';
          const p1 = ((sxBot / SW) * 100).toFixed(3) + '%';
          if (enLayer) enLayer.style.clipPath =
            `polygon(${p0} 0%, 100% 0%, 100% 100%, ${p1} 100%)`;

          // ── Labels: CSS top:1.5rem fixed; x follows line but clamped inside stage ──
          // (label sticks to edge when line is dragged outside)
          const rawLabelX = lineXatVY(rect.top) - rect.left; // stage-local, may be out of bounds
          const LABEL_W   = 32;
          if (splitRatio <= 0.5) {
            const enLeft = Math.min(SW - LABEL_W, Math.max(4, rawLabelX + 14));
            if (labelEN) { labelEN.style.left = enLeft + 'px'; labelEN.style.opacity = '0.7'; }
            if (labelZH) { labelZH.style.opacity = '0'; }
          } else {
            const zhLeft = Math.min(SW - LABEL_W, Math.max(4, rawLabelX - 52));
            if (labelZH) { labelZH.style.left = zhLeft + 'px'; labelZH.style.opacity = '0.7'; }
            if (labelEN) { labelEN.style.opacity = '0'; }
          }
        }

        // ── Snap animation ────────────────────────────────────────────────
        let snapRaf = null;
        function snapTo(target) {
          if (snapRaf) cancelAnimationFrame(snapRaf);
          const from = splitRatio;
          const t0 = performance.now();
          const DUR = 300;
          function step(now) {
            const p = Math.min((now - t0) / DUR, 1);
            const e = 1 - Math.pow(1 - p, 3);
            splitRatio = from + (target - from) * e;
            render();
            if (p < 1) snapRaf = requestAnimationFrame(step);
            else {
              splitRatio = target;
              try { localStorage.setItem(SPLIT_KEY, target); } catch(_) {}
            }
          }
          snapRaf = requestAnimationFrame(step);
        }

        // ── Drag ──────────────────────────────────────────────────────────
        let dragging = false;
        let dragStartCX = 0, dragStartRatio = 0;

        // nearLine: viewport coords directly (SVG is fixed)
        function nearLine(cx, cy) {
          if (cy < 0 || cy > window.innerHeight) return false;
          const { vx0, vx1, VH } = getGeom();
          const lx = vx0 + (vx1 - vx0) * (cy / VH);
          return Math.abs(cx - lx) < HIT_DIST;
        }

        let mouseMoveRaf = null;
        window.addEventListener('mousemove', (e) => {
          const cx = e.clientX, cy = e.clientY;
          if (dragging) {
            if (snapRaf) { cancelAnimationFrame(snapRaf); snapRaf = null; }
            splitRatio = dragStartRatio + (cx - dragStartCX) / stage.offsetWidth;
            if (!mouseMoveRaf) mouseMoveRaf = requestAnimationFrame(() => { mouseMoveRaf = null; render(); });
            document.body.style.cursor = 'grabbing';
          } else {
            // throttle cursor check — no getBoundingClientRect every mousemove
            if (!mouseMoveRaf) mouseMoveRaf = requestAnimationFrame(() => {
              mouseMoveRaf = null;
              document.body.style.cursor = nearLine(cx, cy) ? 'ew-resize' : '';
            });
          }
        }, { passive: true });

        window.addEventListener('mousedown', (e) => {
          if (nearLine(e.clientX, e.clientY)) {
            dragging = true;
            dragStartCX    = e.clientX;
            dragStartRatio = splitRatio;
            document.body.style.cursor = 'grabbing';
            e.preventDefault();
          }
        }, { passive: false });

        window.addEventListener('mouseup', () => {
          if (!dragging) return;
          dragging = false;
          document.body.style.cursor = '';
          snapIfNeeded();
        });

        // Touch
        window.addEventListener('touchstart', (e) => {
          const t = e.touches[0];
          if (nearLine(t.clientX, t.clientY)) {
            dragging = true;
            dragStartCX    = t.clientX;
            dragStartRatio = splitRatio;
          }
        }, { passive: true });

        window.addEventListener('touchmove', (e) => {
          if (!dragging) return;
          splitRatio = dragStartRatio + (e.touches[0].clientX - dragStartCX) / stage.offsetWidth;
          render();
        }, { passive: true });

        window.addEventListener('touchend', () => {
          if (!dragging) return;
          dragging = false;
          snapIfNeeded();
        });

        // snapIfNeeded: snap back only if midX left stage entirely
        function snapIfNeeded() {
          // splitRatio=0 → midX=0 (left edge), splitRatio=1 → midX=SW (right edge)
          if (splitRatio < 0)      snapTo(0);
          else if (splitRatio > 1) snapTo(1);
          else try { localStorage.setItem(SPLIT_KEY, splitRatio); } catch(_) {}
        }

        render();
        updateWings();
        window.addEventListener('resize', () => { render(); updateWings(); requestAnimationFrame(alignSections); }, { passive: true });
        // No scroll listener — SVG line is position:fixed so doesn't move on scroll.
        // clip-path uses getBoundingClientRect which changes on scroll, so update via rAF throttle.
        let scrollRafId = null;
        window.addEventListener('scroll', () => {
          if (!scrollRafId) scrollRafId = requestAnimationFrame(() => { scrollRafId = null; render(); });
        }, { passive: true });
        } // end init()
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
  </body>
</html>
