---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Myles Liu — frontend engineer, AI agent practitioner." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{isHome ? 'mylesio' : `${title} — mylesio`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500&display=swap" rel="stylesheet" />
    <script src="/favicon-anim.js" defer></script>
    <script src="/dino.js" defer></script>
    <style>
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Light.otf') format('opentype');
        font-weight: 300;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-LightItalic.otf') format('opentype');
        font-weight: 300;
        font-style: italic;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Book.otf') format('opentype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-BookItalic.otf') format('opentype');
        font-weight: 400;
        font-style: italic;
        font-display: swap;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:          #f5f2ec;   /* warm off-white / parchment */
        --surface:     #eeeae2;   /* slightly deeper warm white for surfaces */
        --border:      #ddd8ce;   /* warm tan border */
        --text:        #1a1917;   /* near-black with warm undertone */
        --muted:       #6b6860;   /* warm gray, ~4.8:1 on --bg */
        --label:       #9c9890;   /* uppercase labels, decorative only */
        --dim:         #c8c4ba;   /* non-text only: rules, decorative */
        --accent:      #0284c7;   /* deeper sky blue — readable on light bg */
        --accent-mid:  #0ea5e9;   /* mid blue */
        --accent-dim:  #7dd3fc;   /* light blue for hairlines on light bg */
        --accent-wash: #e0eef7;   /* very subtle blue tint for borders/surfaces */
        --green:       #16a34a;   /* semantic green: active / live status */
        --green-dim:   #dcfce7;   /* green wash for tag bg */
        --amber:       #b45309;   /* semantic amber: warning / archived */
        --mono:        'OperatorMonoLig', 'Operator Mono', 'Fira Code', monospace;
        --col:         640px;
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      }

      html { font-size: 15px; }

      body {
        background: transparent;
        color: var(--text);
        font-family: var(--mono);
        font-size: 1rem;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      html { background: var(--bg); }
      body { background: transparent; }

      /* html bg color fills behind fixed navbar */

      ::selection { background: var(--accent); color: #111112; }

      /* ─── Links ──────────────────────────────────── */
      a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
        transition: color 0.18s var(--ease-out-expo),
                    text-decoration-color 0.18s var(--ease-out-expo);
      }
      a:hover {
        color: var(--accent);
        text-decoration-color: var(--accent);
      }

      a.nav-link {
        border-bottom: none;
        color: var(--muted);
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        transition: color 0.18s var(--ease-out-expo);
      }
      a.nav-link:hover { color: var(--text); }
      a.nav-link.active { color: var(--accent); }

      /* ─── Layout ─────────────────────────────────── */
      .page-wrap {
        max-width: var(--col);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* ─── Banner / Dino canvas ───────────────────── */
      .site-header {
        position: sticky;
        top: 0;
        width: 100%;
        height: 48px;           /* navbar height initially */
        background-color: #f5f2ec;
        border-bottom: 1px solid #e2ddd6;
        overflow: hidden;
        z-index: 50;
        transition: height 0.4s ease-out;
      }
      .site-header.expanded {
        height: 170px;
      }

      #dino-canvas {
        position: absolute;
        top: 0; left: 0; right: 0;
        width: 100%;
        height: 170px;
        display: block;
        image-rendering: pixelated;
        image-rendering: crisp-edges;
        z-index: 20;  /* idle: above navbar so dino is visible */
        pointer-events: none;
        cursor: default;
      }
      .site-header.expanded #dino-canvas {
        cursor: pointer;
        /* z-index switched to 5 by JS when dino lands */
      }

      /* ─── Liquid Glass navbar (absolute inside banner) ── */
      header {
        position: absolute;
        top: 0; left: 0; right: 0;
        z-index: 10;
        background: rgba(245, 242, 236, 0.15);
        backdrop-filter: saturate(180%) blur(16px);
        -webkit-backdrop-filter: saturate(180%) blur(16px);
        border-bottom: 1px solid rgba(200, 195, 185, 0.25);
        box-shadow: 0 1px 0 rgba(255,255,255,0.5) inset;
      }

      .nav-inner {
        max-width: var(--col);
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .nav-inner nav {
        flex: 1;          /* nav 撑满中间，lang-toggle 自然靠右 */
        display: flex;
        gap: 1.5rem;
      }

      .logo {
        font-size: 0.9rem;
        font-weight: 400;
        color: #333;
        border-bottom: none;
        letter-spacing: 0.02em;
        transition: color 0.18s var(--ease-out-expo);
        text-decoration: none;
      }
      .logo:hover { color: var(--accent); text-decoration: none; }

      /* nav flex handled by .nav-inner nav above */

      header a.nav-link {
        color: #888;
        text-decoration: none;
        font-size: 0.85rem;
        transition: color 0.15s;
      }
      header a.nav-link:hover { color: #333; }
      header a.nav-link.active { color: var(--accent); font-weight: 500; }

      @media (max-width: 480px) {
        header { gap: 1rem; padding-left: 1rem; padding-right: 1rem; }
      }

      main {
        padding: 1rem 0 5rem;
      }

      footer {
        padding: 1.5rem 0 2.5rem;
        border-top: 1px solid var(--accent-wash);
        display: flex;
        justify-content: space-between;
        font-size: 0.78rem;
        color: var(--muted);
      }
      footer a { color: var(--muted); border-color: transparent; }
      footer a:hover { color: var(--text); border-color: transparent; }

      /* ─── Lang divider ───────────────────────────── */
      /* The split-view lives inside .lang-stage which wraps <main>.
         EN layer is always visible; ZH layer sits on top, clipped from the right.
         The divider SVG line + handle floats at the split position.            */

      .lang-stage {
        position: relative;
      }

      /* EN / 中 labels at top corners */
      .lang-label-en,
      .lang-label-zh {
        position: absolute;
        top: 1.5rem;
        font-size: 0.6rem;
        letter-spacing: 0.12em;
        color: #d946a8;
        pointer-events: none;
        user-select: none;
        z-index: 5;
        opacity: 0.6;
        text-transform: uppercase;
      }
      .lang-label-en { left: 1rem; }
      .lang-label-zh { right: 1rem; }

      /* ZH overlay — clipped; updated via JS custom property */
      .lang-zh-layer {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        /* clip from left edge to split position */
        clip-path: inset(0 0 0 var(--split-x, 60%));
        will-change: clip-path;
      }
      /* zh font inside zh layer */
      .lang-zh-layer {
        font-family: 'Noto Serif SC', 'Source Han Serif CN', 'STSong',
                     Georgia, serif;
        letter-spacing: 0.03em;
      }

      /* Divider line SVG */
      #lang-divider {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        pointer-events: none;
        z-index: 10;
        overflow: visible;
      }
      #lang-divider line {
        stroke: #d946a8;
        stroke-width: 1.5;
        opacity: 0.85;
      }
      /* Handle pill */
      #lang-handle {
        position: absolute;
        top: 50%;
        transform: translate(-50%, -50%);
        z-index: 11;
        width: 28px; height: 44px;
        background: rgba(245,242,236,0.9);
        border: 1.5px solid #d946a8;
        border-radius: 14px;
        cursor: ew-resize;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        box-shadow: 0 2px 14px rgba(217,70,168,0.22);
        transition: box-shadow 0.15s, border-color 0.15s;
        user-select: none;
        touch-action: none;
      }
      #lang-handle:hover, #lang-handle.dragging {
        box-shadow: 0 4px 22px rgba(217,70,168,0.38);
        border-color: #be185d;
      }
      #lang-handle svg {
        width: 12px; height: 12px;
        opacity: 0.6;
        color: #d946a8;
      }

      /* ─── Mobile ─────────────────────────────────── */
      @media (max-width: 480px) {
        html { font-size: 14px; }

        .page-wrap { padding: 0 1rem; }

        header {
          padding: 1rem 0;
          gap: 1rem;
          flex-wrap: wrap;
        }

        footer {
          flex-direction: column;
          gap: 0.4rem;
        }
      }

      /* ─── Page entrance ──────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .reveal {
        opacity: 0;
        animation: fadeUp 0.55s var(--ease-out-expo) forwards;
      }
      .reveal-1 { animation-delay: 0.05s; }
      .reveal-2 { animation-delay: 0.15s; }
      .reveal-3 { animation-delay: 0.25s; }
      .reveal-4 { animation-delay: 0.35s; }

      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; animation: none; }
      }
    </style>
  </head>
  <body>
    <!-- banner contains canvas + absolute navbar on top -->
    <div class="site-header">
      <canvas id="dino-canvas" style="display:block;cursor:pointer;" title="Click to play"></canvas>
      <header>
        <div class="nav-inner">
          <span id="dino-anchor" style="display:inline-block;width:0;height:0;"></span>
          <a class="logo reveal reveal-1" href="/">mylesio</a>
          <nav class="reveal reveal-1">
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/notes') }]} href="/notes" data-en="notes" data-zh="笔记">notes</a>
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/projects') }]} href="/projects" data-en="projects" data-zh="项目">projects</a>
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/about') }]} href="/about" data-en="about" data-zh="关于">about</a>
          </nav>
        </div>
      </header>
    </div>
    <div class="page-wrap">
      <!-- lang-stage: wraps main, hosts the split divider -->
      <div class="lang-stage" id="lang-stage">
        <main id="lang-en-layer">
          <slot />
        </main>

        <!-- ZH layer: same slot content but zh versions, injected per-page -->
        <div class="lang-zh-layer" id="lang-zh-layer" aria-hidden="true"></div>

        <!-- Divider SVG line -->
        <svg id="lang-divider" aria-hidden="true">
          <line id="lang-divider-line" x1="0" y1="0" x2="0" y2="100%"/>
        </svg>

        <!-- Draggable handle -->
        <div id="lang-handle" title="drag to reveal 中文 / English" role="slider" aria-label="Language split" aria-valuemin="0" aria-valuemax="100">
          <svg viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M4 2L2 6L4 10M8 2L10 6L8 10" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <span class="lang-label-en">EN</span>
        <span class="lang-label-zh">中</span>
      </div>

      <footer>
        <span>Myles Liu</span>
        <span><a href="/llms.txt">llms.txt</a></span>
      </footer>
    </div>
    <script>
      // ── Language split-view divider ──────────────────────────────────────
      (function () {
        const SPLIT_KEY = 'lang-split-x';
        const stage   = document.getElementById('lang-stage');
        const handle  = document.getElementById('lang-handle');
        const zhLayer = document.getElementById('lang-zh-layer');
        const divLine = document.getElementById('lang-divider-line');
        if (!stage || !handle) return;

        // Skew angle: 0 = vertical line
        const SKEW_DEG = 0;
        const SKEW_RAD = SKEW_DEG * Math.PI / 180;

        // Default: start mostly to the right (EN dominant)
        let splitRatio = 0.78;
        try {
          const s = parseFloat(localStorage.getItem(SPLIT_KEY));
          if (!isNaN(s)) splitRatio = Math.max(0.05, Math.min(0.95, s));
        } catch(_) {}

        function updateSplit(ratio) {
          splitRatio = Math.max(0.05, Math.min(0.95, ratio));

          const stageRect = stage.getBoundingClientRect();
          const W = stageRect.width;
          const H = stageRect.height;

          // Pixel x of split at mid-height
          const midX = splitRatio * W;

          // Skewed line: top and bottom x offset by tan(angle) * H/2
          const offset = Math.tan(SKEW_RAD) * H / 2;
          const x1 = midX - offset;
          const x2 = midX + offset;

          // Update SVG line
          if (divLine) {
            divLine.setAttribute('x1', x1.toFixed(1));
            divLine.setAttribute('y1', '0');
            divLine.setAttribute('x2', x2.toFixed(1));
            divLine.setAttribute('y2', H.toFixed(1));
          }

          // Update zh layer clip: polygon following the skewed line
          // left edge = 0, right edge = W
          // clip = everything to the RIGHT of the line
          const clipPercX1 = ((x1 / W) * 100).toFixed(2);
          const clipPercX2 = ((x2 / W) * 100).toFixed(2);
          if (zhLayer) {
            zhLayer.style.clipPath =
              `polygon(${clipPercX1}% 0%, 100% 0%, 100% 100%, ${clipPercX2}% 100%)`;
          }

          // Position handle at mid-height, split x
          handle.style.left = `${midX.toFixed(1)}px`;
          handle.style.top  = `${(H / 2).toFixed(1)}px`;

          // Persist
          try { localStorage.setItem(SPLIT_KEY, splitRatio); } catch(_) {}

          // Update data-lang based on which side is dominant
          const lang = splitRatio > 0.5 ? 'en' : 'zh';
          document.documentElement.setAttribute('data-lang', lang);

          // Swap text nodes (nav labels, section labels, etc.)
          document.querySelectorAll('[data-en][data-zh]').forEach(el => {
            if (!el.querySelector('a')) {
              el.textContent = lang === 'zh'
                ? el.getAttribute('data-zh')
                : el.getAttribute('data-en');
            }
          });
        }

        // Init
        updateSplit(splitRatio);

        // Recalc on resize
        window.addEventListener('resize', () => updateSplit(splitRatio), { passive: true });

        // ── Drag logic ──────────────────────────────────────────────────────
        let dragging = false;
        let startX = 0, startRatio = 0;

        function onDown(e) {
          dragging = true;
          handle.classList.add('dragging');
          startX = e.type === 'touchstart' ? e.touches[0].clientX : e.clientX;
          startRatio = splitRatio;
          e.preventDefault();
        }

        function onMove(e) {
          if (!dragging) return;
          const clientX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
          const W = stage.getBoundingClientRect().width;
          const dx = clientX - startX;
          updateSplit(startRatio + dx / W);
        }

        function onUp() {
          if (!dragging) return;
          dragging = false;
          handle.classList.remove('dragging');
        }

        handle.addEventListener('mousedown',  onDown,  { passive: false });
        handle.addEventListener('touchstart', onDown,  { passive: false });
        window.addEventListener('mousemove',  onMove,  { passive: true });
        window.addEventListener('touchmove',  onMove,  { passive: true });
        window.addEventListener('mouseup',    onUp);
        window.addEventListener('touchend',   onUp);
      })();
    </script>
  </body>
</html>
