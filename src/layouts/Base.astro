---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Myles Liu — frontend engineer, AI agent practitioner." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{isHome ? 'mylesio' : `${title} — mylesio`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script src="/favicon-anim.js" defer></script>
    <link rel="stylesheet" href="/trex-runner.css" />
    <script src="/trex-runner.js" defer></script>
    <script defer>
      document.addEventListener('DOMContentLoaded', function() {
        new Runner('.interstitial-wrapper');
      });
    </script>
    <style>
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Light.otf') format('opentype');
        font-weight: 300;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-LightItalic.otf') format('opentype');
        font-weight: 300;
        font-style: italic;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Book.otf') format('opentype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-BookItalic.otf') format('opentype');
        font-weight: 400;
        font-style: italic;
        font-display: swap;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:          #f5f2ec;   /* warm off-white / parchment */
        --surface:     #eeeae2;   /* slightly deeper warm white for surfaces */
        --border:      #ddd8ce;   /* warm tan border */
        --text:        #1a1917;   /* near-black with warm undertone */
        --muted:       #6b6860;   /* warm gray, ~4.8:1 on --bg */
        --label:       #9c9890;   /* uppercase labels, decorative only */
        --dim:         #c8c4ba;   /* non-text only: rules, decorative */
        --accent:      #0284c7;   /* deeper sky blue — readable on light bg */
        --accent-mid:  #0ea5e9;   /* mid blue */
        --accent-dim:  #7dd3fc;   /* light blue for hairlines on light bg */
        --accent-wash: #e0eef7;   /* very subtle blue tint for borders/surfaces */
        --mono:        'OperatorMonoLig', 'Operator Mono', 'Fira Code', monospace;
        --col:         640px;
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      }

      html { font-size: 15px; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--mono);
        font-size: 1rem;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      ::selection { background: var(--accent); color: #111112; }

      /* ─── Links ──────────────────────────────────── */
      a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
        transition: color 0.18s var(--ease-out-expo),
                    text-decoration-color 0.18s var(--ease-out-expo);
      }
      a:hover {
        color: var(--accent);
        text-decoration-color: var(--accent);
      }

      a.nav-link {
        border-bottom: none;
        color: var(--muted);
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        transition: color 0.18s var(--ease-out-expo);
      }
      a.nav-link:hover { color: var(--text); }
      a.nav-link.active { color: var(--accent); }

      /* ─── Layout ─────────────────────────────────── */
      .page-wrap {
        max-width: var(--col);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* ─── Banner / Dino Runner ───────────────────── */
      .site-header {
        position: relative;
        width: 100%;
        height: 200px;
        background-color: #13202e;
        border-bottom: 1px solid rgba(125,211,252,0.15);
        overflow: hidden;
      }

      /* wayou Runner container fills the banner */
      .site-header .interstitial-wrapper {
        position: absolute !important;
        inset: 0;
        width: 100% !important;
        max-width: 100% !important;
        height: 200px !important;
        padding: 0 !important;
        margin: 0 !important;
        overflow: hidden;
      }

      /* runner-container: horizontally centered, fills height */
      .site-header .runner-container {
        position: absolute !important;
        top: 0 !important;
        left: 50% !important;
        transform: translateX(-50%);
        width: 600px !important;
        max-width: 100% !important;
        height: 200px !important;
      }

      /* runner-canvas fills its container */
      .site-header .runner-canvas {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 600px !important;
        max-width: 100% !important;
        height: 200px !important;
      }

      /* hide the icon-offline element (dino icon placeholder) */
      .site-header .icon-offline { display: none !important; }

      /* touch controller covers just the banner, not the whole page */
      .site-header .controller {
        position: absolute !important;
        top: 0 !important; left: 0 !important;
        width: 100% !important;
        height: 200px !important;
      }

      /* ─── Navbar floats above the game ───────────── */
      header {
        position: absolute;
        top: 0; left: 0; right: 0;
        z-index: 10;
        padding: 1rem 0;
        display: flex;
        align-items: center;
        gap: 2rem;
        max-width: var(--col);
        margin: 0 auto;
        /* left/right padding from page-wrap equivalent */
        padding-left: 1.5rem;
        padding-right: 1.5rem;
        /* transparent background so game shows through */
        background: transparent;
      }

      .logo {
        font-size: 0.9rem;
        font-weight: 400;
        color: #e2e8f0;
        border-bottom: none;
        letter-spacing: 0.02em;
        transition: color 0.18s var(--ease-out-expo);
        text-decoration: none;
      }
      .logo:hover { color: var(--accent-mid); text-decoration: none; }

      nav { display: flex; gap: 1.5rem; }

      /* nav links on dark banner */
      .site-header a.nav-link {
        color: rgba(148,163,184,0.85);
        text-decoration: none;
      }
      .site-header a.nav-link:hover { color: #e2e8f0; }
      .site-header a.nav-link.active { color: var(--accent-mid); }

      @media (max-width: 480px) {
        header { gap: 1rem; padding-left: 1rem; padding-right: 1rem; }
      }

      main {
        padding: 1rem 0 5rem;
      }

      footer {
        padding: 1.5rem 0 2.5rem;
        border-top: 1px solid var(--accent-wash);
        display: flex;
        justify-content: space-between;
        font-size: 0.78rem;
        color: var(--muted);
      }
      footer a { color: var(--muted); border-color: transparent; }
      footer a:hover { color: var(--text); border-color: transparent; }

      /* ─── Mobile ─────────────────────────────────── */
      @media (max-width: 480px) {
        html { font-size: 14px; }

        .page-wrap { padding: 0 1rem; }

        header {
          padding: 1rem 0;
          gap: 1rem;
          flex-wrap: wrap;
        }

        footer {
          flex-direction: column;
          gap: 0.4rem;
        }
      }

      /* ─── Page entrance ──────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .reveal {
        opacity: 0;
        animation: fadeUp 0.55s var(--ease-out-expo) forwards;
      }
      .reveal-1 { animation-delay: 0.05s; }
      .reveal-2 { animation-delay: 0.15s; }
      .reveal-3 { animation-delay: 0.25s; }
      .reveal-4 { animation-delay: 0.35s; }

      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; animation: none; }
      }
    </style>
  </head>
  <body>
    <div class="site-header offline">
      <!-- wayou t-rex runner: fills the full 200px banner -->
      <div class="interstitial-wrapper">
        <div id="details-button" style="display:none"></div>
        <div class="icon icon-offline"></div>
        <!-- sprite images required by Runner.loadImages() -->
        <img id="offline-resources-1x" src="/dino-sprite.png" style="display:none" />
        <img id="offline-resources-2x" src="/dino-sprite.png" style="display:none" />
      </div>
      <!-- navbar floats above the game via position:absolute + z-index:10 -->
      <header>
        <a class="logo reveal reveal-1" href="/">mylesio</a>
        <nav class="reveal reveal-1">
          <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/notes') }]} href="/notes">notes</a>
          <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/projects') }]} href="/projects">projects</a>
          <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/about') }]} href="/about">about</a>
        </nav>
      </header>
    </div>
    <div class="page-wrap">
      <main>
        <slot />
      </main>
      <footer>
        <span>Myles Liu</span>
        <span><a href="/llms.txt">llms.txt</a></span>
      </footer>
    </div>
  </body>
</html>
