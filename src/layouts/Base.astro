---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Myles Liu — frontend engineer, AI agent practitioner." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{isHome ? 'mylesio' : `${title} — mylesio`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500&display=swap" rel="stylesheet" />
    <script src="/favicon-anim.js" defer></script>
    <script src="/dino.js" defer></script>
    <style>
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Light.otf') format('opentype');
        font-weight: 300;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-LightItalic.otf') format('opentype');
        font-weight: 300;
        font-style: italic;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Book.otf') format('opentype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-BookItalic.otf') format('opentype');
        font-weight: 400;
        font-style: italic;
        font-display: swap;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:          #f5f2ec;   /* warm off-white / parchment */
        --surface:     #eeeae2;   /* slightly deeper warm white for surfaces */
        --border:      #ddd8ce;   /* warm tan border */
        --text:        #1a1917;   /* near-black with warm undertone */
        --muted:       #6b6860;   /* warm gray, ~4.8:1 on --bg */
        --label:       #9c9890;   /* uppercase labels, decorative only */
        --dim:         #c8c4ba;   /* non-text only: rules, decorative */
        --accent:      #0284c7;   /* deeper sky blue — readable on light bg */
        --accent-mid:  #0ea5e9;   /* mid blue */
        --accent-dim:  #7dd3fc;   /* light blue for hairlines on light bg */
        --accent-wash: #e0eef7;   /* very subtle blue tint for borders/surfaces */
        --green:       #16a34a;   /* semantic green: active / live status */
        --green-dim:   #dcfce7;   /* green wash for tag bg */
        --amber:       #b45309;   /* semantic amber: warning / archived */
        --mono:        'OperatorMonoLig', 'Operator Mono', 'Fira Code', monospace;
        --col:         640px;
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      }

      html { font-size: 15px; }

      body {
        background: transparent;
        color: var(--text);
        font-family: var(--mono);
        font-size: 1rem;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      html { background: var(--bg); }
      body { background: transparent; }

      /* html bg color fills behind fixed navbar */

      ::selection { background: var(--accent); color: #111112; }

      /* ─── Links ──────────────────────────────────── */
      a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
        transition: color 0.18s var(--ease-out-expo),
                    text-decoration-color 0.18s var(--ease-out-expo);
      }
      a:hover {
        color: var(--accent);
        text-decoration-color: var(--accent);
      }

      a.nav-link {
        border-bottom: none;
        color: var(--muted);
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        transition: color 0.18s var(--ease-out-expo);
      }
      a.nav-link:hover { color: var(--text); }
      a.nav-link.active { color: var(--accent); }

      /* ─── Layout ─────────────────────────────────── */
      .page-wrap {
        max-width: var(--col);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* ─── Banner / Dino canvas ───────────────────── */
      .site-header {
        position: sticky;
        top: 0;
        width: 100%;
        height: 48px;           /* navbar height initially */
        background-color: #f5f2ec;
        border-bottom: 1px solid #e2ddd6;
        overflow: hidden;
        z-index: 50;
        transition: height 0.4s ease-out;
      }
      .site-header.expanded {
        height: 170px;
      }

      #dino-canvas {
        position: absolute;
        top: 0; left: 0; right: 0;
        width: 100%;
        height: 170px;
        display: block;
        image-rendering: pixelated;
        image-rendering: crisp-edges;
        z-index: 20;  /* idle: above navbar so dino is visible */
        pointer-events: none;
        cursor: default;
      }
      .site-header.expanded #dino-canvas {
        cursor: pointer;
        /* z-index switched to 5 by JS when dino lands */
      }

      /* ─── Liquid Glass navbar (absolute inside banner) ── */
      header {
        position: absolute;
        top: 0; left: 0; right: 0;
        z-index: 10;
        background: rgba(245, 242, 236, 0.15);
        backdrop-filter: saturate(180%) blur(16px);
        -webkit-backdrop-filter: saturate(180%) blur(16px);
        border-bottom: 1px solid rgba(200, 195, 185, 0.25);
        box-shadow: 0 1px 0 rgba(255,255,255,0.5) inset;
      }

      .nav-inner {
        max-width: var(--col);
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .nav-inner nav {
        flex: 1;          /* nav 撑满中间，lang-toggle 自然靠右 */
        display: flex;
        gap: 1.5rem;
      }

      .logo {
        font-size: 0.9rem;
        font-weight: 400;
        color: #333;
        border-bottom: none;
        letter-spacing: 0.02em;
        transition: color 0.18s var(--ease-out-expo);
        text-decoration: none;
      }
      .logo:hover { color: var(--accent); text-decoration: none; }

      /* nav flex handled by .nav-inner nav above */

      header a.nav-link {
        color: #888;
        text-decoration: none;
        font-size: 0.85rem;
        transition: color 0.15s;
      }
      header a.nav-link:hover { color: #333; }
      header a.nav-link.active { color: var(--accent); font-weight: 500; }

      @media (max-width: 480px) {
        header { gap: 1rem; padding-left: 1rem; padding-right: 1rem; }
      }

      main {
        padding: 1rem 0 5rem;
      }

      footer {
        padding: 1.5rem 0 2.5rem;
        border-top: 1px solid var(--accent-wash);
        display: flex;
        justify-content: space-between;
        font-size: 0.78rem;
        color: var(--muted);
      }
      footer a { color: var(--muted); border-color: transparent; }
      footer a:hover { color: var(--text); border-color: transparent; }

      /* ─── Lang divider ───────────────────────────── */
      /* The split-view lives inside .lang-stage which wraps <main>.
         EN layer is always visible; ZH layer sits on top, clipped from the right.
         The divider SVG line + handle floats at the split position.            */

      .lang-stage {
        position: relative;
        overflow: hidden; /* clips the diagonal line at stage boundaries */
      }
      #lang-en-layer {
        position: relative;
        will-change: clip-path;
        background: var(--bg); /* cover ZH layer on the left side */
      }
      /* ZH layer sits BELOW EN layer; EN clips left side exposing ZH on right */
      .lang-zh-layer {
        position: absolute;
        top: 0; left: 0;
        width: 100%;
        min-height: 100%;
        /* no clip-path needed — ZH is always fully rendered, EN covers it on the left */
      }

      /* EN / 中 labels at top corners */
      .lang-label-en,
      .lang-label-zh {
        position: absolute;
        top: 1.5rem;
        font-size: 0.6rem;
        letter-spacing: 0.12em;
        color: #d946a8;
        pointer-events: none;
        user-select: none;
        z-index: 5;
        opacity: 0.6;
        text-transform: uppercase;
      }
      /* initial positions overridden by JS */
      .lang-label-en { left: 1rem; }
      .lang-label-zh { left: 60%; }

      /* ZH layer font */
      .lang-zh-layer {
        font-family: 'Noto Serif SC', 'Source Han Serif CN', 'STSong',
                     Georgia, serif;
        letter-spacing: 0.03em;
      }

      /* Divider line SVG */
      #lang-divider {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        pointer-events: none;
        z-index: 10;
        overflow: visible;
      }
      #lang-divider line {
        stroke: #d946a8;
        stroke-width: 1.5;
        opacity: 0.85;
      }


      /* ─── Mobile ─────────────────────────────────── */
      @media (max-width: 480px) {
        html { font-size: 14px; }

        .page-wrap { padding: 0 1rem; }

        header {
          padding: 1rem 0;
          gap: 1rem;
          flex-wrap: wrap;
        }

        footer {
          flex-direction: column;
          gap: 0.4rem;
        }
      }

      /* ─── Page entrance ──────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .reveal {
        opacity: 0;
        animation: fadeUp 0.55s var(--ease-out-expo) forwards;
      }
      .reveal-1 { animation-delay: 0.05s; }
      .reveal-2 { animation-delay: 0.15s; }
      .reveal-3 { animation-delay: 0.25s; }
      .reveal-4 { animation-delay: 0.35s; }

      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; animation: none; }
      }
    </style>
  </head>
  <body>
    <!-- banner contains canvas + absolute navbar on top -->
    <div class="site-header">
      <canvas id="dino-canvas" style="display:block;cursor:pointer;" title="Click to play"></canvas>
      <header>
        <div class="nav-inner">
          <span id="dino-anchor" style="display:inline-block;width:0;height:0;"></span>
          <a class="logo reveal reveal-1" href="/">mylesio</a>
          <nav class="reveal reveal-1">
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/notes') }]} href="/notes" data-en="notes" data-zh="笔记">notes</a>
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/projects') }]} href="/projects" data-en="projects" data-zh="项目">projects</a>
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/about') }]} href="/about" data-en="about" data-zh="关于">about</a>
          </nav>
        </div>
      </header>
    </div>
    <div class="page-wrap">
      <!-- lang-stage: wraps main, hosts the split divider -->
      <div class="lang-stage" id="lang-stage">
        <!-- ZH layer BELOW EN layer; EN clips itself so ZH shows through on right side -->
        <div class="lang-zh-layer" id="lang-zh-layer" aria-hidden="true"></div>

        <main id="lang-en-layer">
          <slot />
        </main>

        <!-- Divider SVG: full stage size, line stays within SVG bounds -->
        <svg id="lang-divider" aria-hidden="true"
             style="position:absolute;top:0;left:0;width:100%;height:100%;overflow:hidden;pointer-events:none;z-index:10;">
          <line id="lang-divider-line" stroke="#d946a8" stroke-width="1.5" opacity="0.85"/>
        </svg>

        <span class="lang-label-en" id="lang-label-en">EN</span>
        <span class="lang-label-zh" id="lang-label-zh">中</span>
      </div>

      <footer>
        <span>Myles Liu</span>
        <span><a href="/llms.txt">llms.txt</a></span>
      </footer>
    </div>
    <script>
    <script>
      // ── Language split-view divider ──────────────────────────────────────
      (function () {
        const SPLIT_KEY = 'lang-split-x';
        const stage   = document.getElementById('lang-stage');
        const enLayer = document.getElementById('lang-en-layer');
        const zhLayer = document.getElementById('lang-zh-layer');
        const svgEl   = document.getElementById('lang-divider');
        const divLine = document.getElementById('lang-divider-line');
        const labelEN = document.getElementById('lang-label-en');
        const labelZH = document.getElementById('lang-label-zh');
        if (!stage || !divLine) return;

        const SKEW_DEG = 15; // ~75° from horizontal (nearly vertical)
        const SKEW_RAD = SKEW_DEG * Math.PI / 180;
        const HIT_DIST = 28;   // px from line to activate cursor
        const SNAP_MIN = 0.05; // snap back inside these bounds on release
        const SNAP_MAX = 0.95;

        // splitRatio: 0~1, based on VIEWPORT width
        // This means clientX / innerWidth = splitRatio at the mid-height of the line
        let splitRatio = 0.80;
        try {
          const s = parseFloat(localStorage.getItem(SPLIT_KEY));
          if (!isNaN(s)) splitRatio = s; // restore as-is, snap will fix if needed
        } catch(_) {}

        // ── Geometry: stage-local coords throughout ───────────────────────
        // ── Geometry: pure stage-local, scroll-independent ───────────────
        // Line tilts right (\): top-left to bottom-right.
        // Anchor = stage center (SH/2). No BoundingClientRect → no scroll drift.
        // off = horizontal half-span; uses window.innerHeight so angle ≈12° visually.

        function getGeom() {
          const SW  = stage.offsetWidth;
          const SH  = stage.offsetHeight;
          const off = Math.tan(SKEW_RAD) * window.innerHeight / 2;
          const midX = splitRatio * SW;
          // Right-leaning (\): top x < midX, bottom x > midX
          const x0 = midX + off; // x at y=0   top-right → bottom-left (/ direction)
          const xH = midX - off; // x at y=SH
          return { x0, xH, SW, SH };
        }

        function lineXatSY(sy) {
          const { x0, xH, SH } = getGeom();
          return x0 + (xH - x0) * (sy / SH);
        }

        // ── Render ────────────────────────────────────────────────────────
        function render() {
          const { x0, xH, SW, SH } = getGeom();

          // SVG line in stage-local coords
          divLine.setAttribute('x1', x0.toFixed(1));
          divLine.setAttribute('y1', '0');
          divLine.setAttribute('x2', xH.toFixed(1));
          divLine.setAttribute('y2', SH.toFixed(1));

          // clip-path percentages (relative to stage)
          const p0 = ((x0 / SW) * 100).toFixed(3) + '%';
          const p1 = ((xH / SW) * 100).toFixed(3) + '%';

          // Left of line = ZH (drag left → more ZH)
          // Right of line = EN (drag right → more EN)
          // EN layer has background, clips to RIGHT side; ZH is below, exposed on LEFT
          if (enLayer) enLayer.style.clipPath =
            `polygon(${p0} 0%, 100% 0%, 100% 100%, ${p1} 100%)`;

          // Labels: ZH on left of line, EN on right of line
          // Place labels at viewport-center height within stage (always visible)
          const rect    = stage.getBoundingClientRect();
          const labelSY = Math.max(0, Math.min(SH, window.innerHeight / 2 - rect.top));
          const labelX  = lineXatSY(labelSY);
          // ZH label: left of line (ZH content is on the left)
          if (labelZH) {
            labelZH.style.left = Math.max(4, labelX - 52) + 'px';
            labelZH.style.top  = (labelSY - 10) + 'px';
          }
          // EN label: right of line (EN content is on the right)
          if (labelEN) {
            labelEN.style.left = (labelX + 14) + 'px';
            labelEN.style.top  = (labelSY + 10) + 'px';
          }
        }

        // ── Snap animation ────────────────────────────────────────────────
        let snapRaf = null;
        function snapTo(target) {
          if (snapRaf) cancelAnimationFrame(snapRaf);
          const from = splitRatio;
          const t0 = performance.now();
          const DUR = 300;
          function step(now) {
            const p = Math.min((now - t0) / DUR, 1);
            const e = 1 - Math.pow(1 - p, 3);
            splitRatio = from + (target - from) * e;
            render();
            if (p < 1) snapRaf = requestAnimationFrame(step);
            else {
              splitRatio = target;
              try { localStorage.setItem(SPLIT_KEY, target); } catch(_) {}
            }
          }
          snapRaf = requestAnimationFrame(step);
        }

        // ── Drag ──────────────────────────────────────────────────────────
        let dragging = false;
        let dragStartCX = 0, dragStartRatio = 0;

        // nearLine: convert clientX/Y to stage-local, check distance to line
        function nearLine(cx, cy) {
          const rect = stage.getBoundingClientRect();
          const sx = cx - rect.left;
          const sy = cy - rect.top;
          const SH = stage.offsetHeight;
          if (sy < 0 || sy > SH) return false;
          return Math.abs(sx - lineXatSY(sy)) < HIT_DIST;
        }

        window.addEventListener('mousemove', (e) => {
          if (dragging) {
            if (snapRaf) { cancelAnimationFrame(snapRaf); snapRaf = null; }
            splitRatio = dragStartRatio + (e.clientX - dragStartCX) / stage.offsetWidth;
            render();
            document.body.style.cursor = 'grabbing';
          } else {
            document.body.style.cursor = nearLine(e.clientX, e.clientY) ? 'ew-resize' : '';
          }
        }, { passive: true });

        window.addEventListener('mousedown', (e) => {
          if (nearLine(e.clientX, e.clientY)) {
            dragging = true;
            dragStartCX    = e.clientX;
            dragStartRatio = splitRatio;
            document.body.style.cursor = 'grabbing';
            e.preventDefault();
          }
        }, { passive: false });

        window.addEventListener('mouseup', () => {
          if (!dragging) return;
          dragging = false;
          document.body.style.cursor = '';
          if (splitRatio < SNAP_MIN)      snapTo(SNAP_MIN);
          else if (splitRatio > SNAP_MAX) snapTo(SNAP_MAX);
          else try { localStorage.setItem(SPLIT_KEY, splitRatio); } catch(_) {}
        });

        // Touch
        window.addEventListener('touchstart', (e) => {
          const t = e.touches[0];
          if (nearLine(t.clientX, t.clientY)) {
            dragging = true;
            dragStartCX    = t.clientX;
            dragStartRatio = splitRatio;
          }
        }, { passive: true });

        window.addEventListener('touchmove', (e) => {
          if (!dragging) return;
          splitRatio = dragStartRatio + (e.touches[0].clientX - dragStartCX) / stage.offsetWidth;
          render();
        }, { passive: true });

        window.addEventListener('touchend', () => {
          if (!dragging) return;
          dragging = false;
          if (splitRatio < SNAP_MIN)      snapTo(SNAP_MIN);
          else if (splitRatio > SNAP_MAX) snapTo(SNAP_MAX);
          else try { localStorage.setItem(SPLIT_KEY, splitRatio); } catch(_) {}
        });

        // Labels need scroll update (their viewport position changes); line geometry does not
        function renderLabels() {
          const { SH } = getGeom();
          const rect    = stage.getBoundingClientRect();
          const labelSY = Math.max(0, Math.min(SH, window.innerHeight / 2 - rect.top));
          const labelX  = lineXatSY(labelSY);
          if (labelZH) {
            labelZH.style.left = Math.max(4, labelX - 52) + 'px';
            labelZH.style.top  = (labelSY - 10) + 'px';
          }
          if (labelEN) {
            labelEN.style.left = (labelX + 14) + 'px';
            labelEN.style.top  = (labelSY + 10) + 'px';
          }
        }

        render();
        window.addEventListener('resize', render, { passive: true });
        window.addEventListener('scroll', renderLabels, { passive: true });
      })();
    </script>
    </script>
  </body>
</html>
