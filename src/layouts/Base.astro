---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Myles Liu — frontend engineer, AI agent practitioner." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{isHome ? 'mylesio' : `${title} — mylesio`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script src="/favicon-anim.js" defer></script>
    <script src="/dino.js" defer></script>
    <style>
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Light.otf') format('opentype');
        font-weight: 300;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-LightItalic.otf') format('opentype');
        font-weight: 300;
        font-style: italic;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-Book.otf') format('opentype');
        font-weight: 400;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: 'OperatorMonoLig';
        src: url('/fonts/OperatorMonoLig-BookItalic.otf') format('opentype');
        font-weight: 400;
        font-style: italic;
        font-display: swap;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg:          #f5f2ec;   /* warm off-white / parchment */
        --surface:     #eeeae2;   /* slightly deeper warm white for surfaces */
        --border:      #ddd8ce;   /* warm tan border */
        --text:        #1a1917;   /* near-black with warm undertone */
        --muted:       #6b6860;   /* warm gray, ~4.8:1 on --bg */
        --label:       #9c9890;   /* uppercase labels, decorative only */
        --dim:         #c8c4ba;   /* non-text only: rules, decorative */
        --accent:      #0284c7;   /* deeper sky blue — readable on light bg */
        --accent-mid:  #0ea5e9;   /* mid blue */
        --accent-dim:  #7dd3fc;   /* light blue for hairlines on light bg */
        --accent-wash: #e0eef7;   /* very subtle blue tint for borders/surfaces */
        --mono:        'OperatorMonoLig', 'Operator Mono', 'Fira Code', monospace;
        --col:         640px;
        --ease-out-expo: cubic-bezier(0.16, 1, 0.3, 1);
      }

      html { font-size: 15px; }

      body {
        background: transparent;
        color: var(--text);
        font-family: var(--mono);
        font-size: 1rem;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
      }

      html { background: var(--bg); }
      body { background: transparent; }

      /* html bg color fills behind fixed navbar */

      ::selection { background: var(--accent); color: #111112; }

      /* ─── Links ──────────────────────────────────── */
      a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-color: color-mix(in srgb, var(--accent) 30%, transparent);
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
        transition: color 0.18s var(--ease-out-expo),
                    text-decoration-color 0.18s var(--ease-out-expo);
      }
      a:hover {
        color: var(--accent);
        text-decoration-color: var(--accent);
      }

      a.nav-link {
        border-bottom: none;
        color: var(--muted);
        font-size: 0.8rem;
        letter-spacing: 0.04em;
        transition: color 0.18s var(--ease-out-expo);
      }
      a.nav-link:hover { color: var(--text); }
      a.nav-link.active { color: var(--accent); }

      /* ─── Layout ─────────────────────────────────── */
      .page-wrap {
        max-width: var(--col);
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* ─── Banner / Dino canvas ───────────────────── */
      .site-header {
        position: sticky;
        top: 0;
        width: 100%;
        height: 48px;           /* idle: same as navbar */
        background-color: #f5f2ec;
        border-bottom: 1px solid #e2ddd6;
        overflow: hidden;
        z-index: 50;
        transition: height 0.5s cubic-bezier(0.34, 1.56, 0.64, 1); /* spring */
      }
      .site-header.expanded {
        height: 150px;
      }

      #dino-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        image-rendering: pixelated;
        image-rendering: crisp-edges;
      }

      /* ─── Liquid Glass navbar (absolute inside banner) ── */
      header {
        position: absolute;
        top: 0; left: 0; right: 0;
        z-index: 10;
        background: rgba(245, 242, 236, 0.15);
        backdrop-filter: saturate(180%) blur(16px);
        -webkit-backdrop-filter: saturate(180%) blur(16px);
        border-bottom: 1px solid rgba(200, 195, 185, 0.25);
        box-shadow: 0 1px 0 rgba(255,255,255,0.5) inset;
      }

      .nav-inner {
        max-width: var(--col);
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 2rem;
      }

      #dino-logo {
        display: block;
        width: 24px;
        height: 24px;
        image-rendering: pixelated;
        flex-shrink: 0;
        cursor: pointer;
      }

      .logo {
        font-size: 0.9rem;
        font-weight: 400;
        color: #333;
        border-bottom: none;
        letter-spacing: 0.02em;
        transition: color 0.18s var(--ease-out-expo);
        text-decoration: none;
      }
      .logo:hover { color: var(--accent); text-decoration: none; }

      nav { display: flex; gap: 1.5rem; }

      header a.nav-link {
        color: #888;
        text-decoration: none;
        font-size: 0.85rem;
        transition: color 0.15s;
      }
      header a.nav-link:hover { color: #333; }
      header a.nav-link.active { color: var(--accent); font-weight: 500; }

      @media (max-width: 480px) {
        header { gap: 1rem; padding-left: 1rem; padding-right: 1rem; }
      }

      main {
        padding: 1rem 0 5rem;
      }

      footer {
        padding: 1.5rem 0 2.5rem;
        border-top: 1px solid var(--accent-wash);
        display: flex;
        justify-content: space-between;
        font-size: 0.78rem;
        color: var(--muted);
      }
      footer a { color: var(--muted); border-color: transparent; }
      footer a:hover { color: var(--text); border-color: transparent; }

      /* ─── Mobile ─────────────────────────────────── */
      @media (max-width: 480px) {
        html { font-size: 14px; }

        .page-wrap { padding: 0 1rem; }

        header {
          padding: 1rem 0;
          gap: 1rem;
          flex-wrap: wrap;
        }

        footer {
          flex-direction: column;
          gap: 0.4rem;
        }
      }

      /* ─── Page entrance ──────────────────────────── */
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      .reveal {
        opacity: 0;
        animation: fadeUp 0.55s var(--ease-out-expo) forwards;
      }
      .reveal-1 { animation-delay: 0.05s; }
      .reveal-2 { animation-delay: 0.15s; }
      .reveal-3 { animation-delay: 0.25s; }
      .reveal-4 { animation-delay: 0.35s; }

      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; animation: none; }
      }
    </style>
  </head>
  <body>
    <!-- banner contains canvas + absolute navbar on top -->
    <div class="site-header">
      <canvas id="dino-canvas" style="display:block;cursor:pointer;" title="Click to play / toggle auto mode"></canvas>
      <header>
        <div class="nav-inner">
          <canvas id="dino-logo" width="24" height="24" title="click anywhere to start"></canvas>
        <a class="logo reveal reveal-1" href="/">mylesio</a>
          <nav class="reveal reveal-1">
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/notes') }]} href="/notes">notes</a>
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/projects') }]} href="/projects">projects</a>
            <a class:list={["nav-link", { active: Astro.url.pathname.startsWith('/about') }]} href="/about">about</a>
          </nav>
        </div>
      </header>
    </div>
    <div class="page-wrap">
      <main>
        <slot />
      </main>
      <footer>
        <span>Myles Liu</span>
        <span><a href="/llms.txt">llms.txt</a></span>
      </footer>
    </div>
  </body>
</html>
