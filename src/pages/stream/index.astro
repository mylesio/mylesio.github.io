---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

const entries = (await getCollection('stream'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const rendered = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);
---

<Base title="Stream" description="A living log of what I'm thinking about." noindex={true}>
  <section class="page-header">
    <h1 class="page-title" data-en="stream" data-zh="思维流">stream</h1>
    <p class="page-subtitle">
      a log of what I'm actually thinking about, day to day. also ran <a href="/stream/result">Prism</a> on myself — an AI-generated six-axis profile.
    </p>
  </section>

  <div class="stream-list">
    {rendered.map(({ entry, Content }) => (
      <article class="stream-entry lang-section">
        <div class="entry-meta">
          <time datetime={entry.data.date.toISOString()}>
            {entry.data.date.toISOString().slice(0, 10)}
          </time>
        </div>
        <div class="entry-body">
          <Content />
        </div>
      </article>
    ))}
  </div>

  <!-- ZH layer template for divider — mirrors the EN content above with ZH text -->
  <template id="zh-content-tpl">
    <section class="page-header">
      <h1 class="page-title">思维流</h1>
      <p class="page-subtitle">每天在想什么，AI 提炼，持续更新。也用 <a href="/stream/result">Prism</a> 跑了一次自我分析——六维 AI 生成画像。</p>
    </section>
    <div class="stream-list">
      {rendered.map(({ entry }) => (
        <article class="stream-entry lang-section">
          <div class="entry-meta">
            <time datetime={entry.data.date.toISOString()}>
              {entry.data.date.toISOString().slice(0, 10)}
            </time>
          </div>
          <div class="entry-body">
            {entry.data.zh
              ? <p>{entry.data.zh}</p>
              : <p style="color:var(--muted);font-style:italic">（暂无中文版本）</p>
            }
          </div>
        </article>
      ))}
    </div>
  </template>
</Base>

<style is:global>
  .stream-list {
    display: flex;
    flex-direction: column;
  }

  .stream-entry {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0 2rem;
    padding: 1.75rem 0;
    border-top: 1px solid var(--border, #e8e4dc);
    align-items: start;
  }
  .stream-entry:last-child {
    border-bottom: 1px solid var(--border, #e8e4dc);
  }

  .entry-meta time {
    font-size: 0.72rem;
    color: var(--muted);
    font-family: 'OperatorMono', 'SF Mono', monospace;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  .entry-body {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--text);
  }
  .entry-body :global(p) {
    margin: 0 0 0.6em;
  }
  .entry-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .entry-body :global(code) {
    font-family: 'OperatorMono', 'SF Mono', monospace;
    font-size: 0.82em;
    background: var(--code-bg, #f0ece4);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  @media (max-width: 600px) {
    .stream-entry {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .entry-meta time {
      font-size: 0.68rem;
    }
  }
</style>
