---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map(note => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();
const dateStr = note.data.date.toISOString().slice(0, 10);
---

<Base title={note.data.title} description={note.data.description}>
  <article>
    <header class="post-header">
      <p class="post-meta">
        <a href="/notes">notes</a>
        <span class="sep">/</span>
        <time datetime={note.data.date.toISOString()}>{dateStr}</time>
      </p>
      <h1 class="post-title">{note.data.title}</h1>
      {note.data.tags && (
        <div class="tags">
          {note.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .post-header {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .post-meta {
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .post-meta a { border-bottom: none; color: var(--muted); }
  .post-meta a:hover { color: var(--accent); }
  .sep { color: var(--dim); }
  .post-title {
    font-size: 1.4rem;
    font-weight: 500;
    color: #fff;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--border);
    color: var(--muted);
    letter-spacing: 0.04em;
  }
</style>

<style is:global>
  .prose { font-size: 0.925rem; line-height: 1.75; }
  .prose h2 { font-size: 1rem; font-weight: 500; color: #fff; margin: 2.5rem 0 0.75rem; letter-spacing: 0.01em; }
  .prose h3 { font-size: 0.9rem; font-weight: 500; color: var(--text); margin: 2rem 0 0.5rem; }
  .prose p { margin-bottom: 1.25rem; }
  .prose ul, .prose ol { margin: 0 0 1.25rem 1.25rem; }
  .prose li { margin-bottom: 0.3rem; }
  .prose a { color: var(--accent); border-color: transparent; }
  .prose a:hover { border-color: var(--accent); }
  .prose code {
    font-family: var(--mono);
    font-size: 0.85em;
    background: var(--surface);
    padding: 0.15em 0.4em;
    border: 1px solid var(--border);
  }
  .prose pre {
    background: var(--surface) !important;
    border: 1px solid var(--border);
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    font-size: 0.85em;
  }
  .prose pre code { background: none; border: none; padding: 0; }
  .prose blockquote {
    border-left: 2px solid var(--dim);
    padding-left: 1.25rem;
    color: var(--muted);
    margin: 1.5rem 0;
    font-style: normal;
    font-weight: 300;
  }
  .prose hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  .prose strong { color: #fff; font-weight: 500; }
</style>
