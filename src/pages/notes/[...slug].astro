---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allNotes = await getCollection('notes');
  // Only generate pages for EN notes (zh notes are embedded inside en pages)
  const enNotes = allNotes.filter(n => (n.data.lang ?? 'en') === 'en');
  const zhNotes = allNotes.filter(n => n.data.lang === 'zh');

  return enNotes.map(note => {
    const zhNote = note.data.zhSlug
      ? zhNotes.find(z => z.slug === note.data.zhSlug)
      : null;
    return {
      params: { slug: note.slug },
      props: { note, zhNote: zhNote ?? null },
    };
  });
}

const { note, zhNote } = Astro.props;
const { Content: ContentEN } = await note.render();
const ContentZH = zhNote ? (await zhNote.render()).Content : null;
const dateStr = note.data.date.toISOString().slice(0, 10);
---

<Base title={note.data.title} description={note.data.description}>
  <article>
    <header class="post-header">
      <p class="post-meta">
        <a href="/notes" data-en="notes" data-zh="笔记">notes</a>
        <span class="sep">/</span>
        <time datetime={note.data.date.toISOString()}>{dateStr}</time>
      </p>
      <!-- title: show en or zh depending on lang -->
      <h1 class="post-title"
          data-en={note.data.title}
          data-zh={zhNote?.data.title ?? note.data.title}>
        {note.data.title}
      </h1>
      {note.data.tags && (
        <div class="tags">
          {note.data.tags.map((tag: string) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- EN content -->
    <div class="prose" data-show-lang="en">
      <ContentEN />
    </div>

    <!-- ZH content: rendered here, moved to #lang-zh-layer by JS -->
    {ContentZH && (
      <template id="zh-content-tpl">
        <header class="post-header">
          <p class="post-meta">
            <a href="/notes">笔记</a>
            <span class="sep">/</span>
            <time datetime={note.data.date.toISOString()}>{dateStr}</time>
          </p>
          <h1 class="post-title">{zhNote?.data.title ?? note.data.title}</h1>
          {note.data.tags && (
            <div class="tags">
              {note.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </header>
        <div class="prose">
          <ContentZH />
        </div>
      </template>
    )}
  </article>
</Base>

<style>
  .post-header {
    padding: 2rem 0 2.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .post-meta {
    font-size: 0.75rem;
    color: var(--muted);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .post-meta a { border-bottom: none; color: var(--muted); }
  .post-meta a:hover { color: var(--accent); }
  .sep { color: var(--dim); }
  .post-title {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border: 1px solid var(--accent-wash);
    background: var(--accent-wash);
    color: var(--accent);
    letter-spacing: 0.04em;
  }
</style>

<style is:global>
  .prose { font-size: 0.925rem; line-height: 1.75; }
  .prose h2 { font-size: 1rem; font-weight: 500; color: var(--accent); margin: 2.5rem 0 0.75rem; letter-spacing: 0.01em; }
  .prose h3 { font-size: 0.9rem; font-weight: 500; color: var(--text); margin: 2rem 0 0.5rem; }
  .prose p { margin-bottom: 1.25rem; }
  .prose ul, .prose ol { margin: 0 0 1.25rem 1.25rem; }
  .prose li { margin-bottom: 0.3rem; }
  .prose a { color: var(--accent); border-color: transparent; }
  .prose a:hover { border-color: var(--accent); }
  .prose code {
    font-family: var(--mono);
    background: var(--surface);
    padding: 0.15em 0.4em;
    border: 1px solid var(--border);
  }
  .prose pre {
    background: #1e1e2e !important;
    border: 1px solid #2d2d3f;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    color: #cdd6f4;
    border-radius: 4px;
  }
  .prose pre code { background: none; border: none; padding: 0; color: inherit; }
  .prose blockquote {
    border-left: 2px solid var(--dim);
    padding-left: 1.25rem;
    color: var(--muted);
    margin: 1.5rem 0;
    font-style: normal;
    font-weight: 300;
  }
  .prose hr { border: none; border-top: 1px solid var(--border); margin: 2.5rem 0; }
  .prose strong { color: var(--text); font-weight: 500; }

  /* prose table */
  .prose table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; }
  .prose th { text-align: left; padding: 0.5rem 0.75rem; border-bottom: 2px solid var(--border); color: var(--muted); font-weight: 400; letter-spacing: 0.04em; font-size: 0.8em; text-transform: uppercase; }
  .prose td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border); vertical-align: top; }
</style>


