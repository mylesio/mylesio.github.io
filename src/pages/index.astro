---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Base title="Home">
  <section class="hero reveal reveal-2">
    <p class="hero-name">Myles Liu <span class="hero-is">is</span></p>
    <p class="hero-sub"><span id="typewriter"></span><span class="type-cursor">▌</span></p>
  </section>

  <script>
    const phrases = [
      'a frontend engineer',
      'building monitoring systems',
      'exploring AI agents',
      'writing open-source tools',
    ];
    let pi = 0, ci = 0, deleting = false;
    const el = document.getElementById('typewriter');
    if (el) {
      function tick() {
        const phrase = phrases[pi];
        if (!deleting) {
          ci++;
          el.textContent = phrase.slice(0, ci);
          if (ci === phrase.length) {
            deleting = true;
            setTimeout(tick, 1800);
            return;
          }
          setTimeout(tick, 68);
        } else {
          ci--;
          el.textContent = phrase.slice(0, ci);
          if (ci === 0) {
            deleting = false;
            pi = (pi + 1) % phrases.length;
            setTimeout(tick, 400);
            return;
          }
          setTimeout(tick, 38);
        }
      }
      setTimeout(tick, 900);
    }
  </script>

  {notes.length > 0 && (
    <section class="block reveal reveal-3">
      <p class="section-label">notes</p>
      <ul class="note-list">
        {notes.map((note, i) => (
          <li class="note-item" style={`--i:${i}`}>
            <a href={`/notes/${note.slug}`} class="note-link">
              <span class="note-title">{note.data.title}</span>
              <time datetime={note.data.date.toISOString()}>
                {note.data.date.toISOString().slice(0, 10)}
              </time>
            </a>
          </li>
        ))}
      </ul>
      <a href="/notes" class="section-more">all notes →</a>
    </section>
  )}

  <section class="block projects-block reveal reveal-4">
    <p class="section-label">projects</p>
    <div class="project-grid">
      <a href="https://github.com/mylesio/prism" class="project-card" style="--i:0">
        <span class="project-name">prism</span>
        <span class="project-desc">AI personal profile engine — parses conversations into structured personality insights</span>
      </a>
      <a href="https://github.com/mylesio/ant-protocol" class="project-card" style="--i:1">
        <span class="project-name">ant-protocol</span>
        <span class="project-desc">Multi-agent governance — task lifecycle, memory, hooks, queen orchestration</span>
      </a>
      <a href="https://github.com/mylesio/oasis-openclaw" class="project-card" style="--i:2">
        <span class="project-name">oasis-openclaw</span>
        <span class="project-desc">Full agent intelligence injected into OASIS social simulation platform</span>
      </a>
      <a href="https://github.com/mylesio/worldmind" class="project-card" style="--i:3">
        <span class="project-name">worldmind</span>
        <span class="project-desc">Multi-agent world model engine — perceive, reason, and predict complex ecosystems</span>
      </a>
      <a href="https://github.com/mylesio/temporal-crystal" class="project-card" style="--i:4">
        <span class="project-name">temporal-crystal</span>
        <span class="project-desc">Living memory for AI agents — memories that evolve, compress, and crystallize</span>
      </a>
      <a href="https://github.com/mylesio/rumex" class="project-card" style="--i:5">
        <span class="project-name">rumex</span>
        <span class="project-desc">Per-agent memory protocol — persistent context across sessions</span>
      </a>
    </div>
    <a href="/projects" class="section-more">all projects →</a>
  </section>
</Base>

<style>
  .hero {
    padding: 1rem 0 2.5rem;
    margin-bottom: 3rem;
  }
  .hero-name {
    font-size: 2.4rem;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }
  .hero-is {
    color: var(--muted);
    font-size: 2.2rem;
    font-weight: 300;
    letter-spacing: -0.01em;
  }
  .hero-sub {
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 300;
    letter-spacing: 0.01em;
    min-height: 1.4em;
    display: flex;
    align-items: baseline;
    gap: 1px;
  }
  @keyframes blink { 50% { opacity: 0; } }
  .type-cursor {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
    margin-left: 1px;
    font-size: 0.88rem;
  }
  @media (prefers-reduced-motion: reduce) {
    .type-cursor { animation: none; }
  }

  /* ── Sections ────────────────────────────────── */
  .block { margin-bottom: 4rem; }

  .section-label {
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1.5rem;
    font-weight: 400;
  }

  .section-more {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.78rem;
    color: var(--muted);
    text-decoration: none;
    letter-spacing: 0.03em;
    transition: color 0.18s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .section-more:hover { color: var(--accent); }

  /* ── Notes list ─────────────────────────────── */
  .note-list { list-style: none; }

  .note-item {
    opacity: 0;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.2s + var(--i, 0) * 0.06s);
  }
  @media (prefers-reduced-motion: reduce) {
    .note-item { opacity: 1; animation: none; }
  }

  .note-link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 2rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: border-color 0.18s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .note-item:first-child .note-link {
    border-top: 1px solid var(--border);
  }
  .note-link:hover {
    border-color: var(--accent);
  }

  .note-title {
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 400;
    transition: color 0.18s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .note-link:hover .note-title { color: var(--accent); }

  .note-link time {
    color: var(--label);
    font-size: 0.72rem;
    white-space: nowrap;
    font-weight: 300;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  /* ── Projects grid ──────────────────────────── */
  .project-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--border);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.25rem 1.5rem;
    background: var(--bg);
    text-decoration: none;
    transition: background 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    opacity: 0;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.3s + var(--i, 0) * 0.08s);
  }
  @media (prefers-reduced-motion: reduce) {
    .project-card { opacity: 1; animation: none; }
  }
  .project-card:hover {
    background: var(--surface);
  }

  .project-name {
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--text);
    transition: color 0.18s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .project-card:hover .project-name { color: var(--accent); }

  .project-desc {
    font-size: 0.75rem;
    color: var(--muted);
    font-weight: 300;
    line-height: 1.5;
    letter-spacing: 0.01em;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Mobile ─────────────────────────────────── */
  @media (max-width: 480px) {
    .hero { padding: 0.75rem 0 1.5rem; }
    .hero-name { font-size: 1.7rem; }

    .note-link {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }

    .project-card {
      padding: 1rem;
    }
  }
</style>
