---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Base title="Home">
  <section class="hero">
    <p class="hero-name">Myles Liu<span class="cursor">▌</span></p>
    <p class="hero-sub">frontend engineer · monitoring systems · AI agents</p>
  </section>

  {notes.length > 0 && (
    <section class="block">
      <p class="section-label">notes</p>
      <ul class="list">
        {notes.map(note => (
          <li class="list-item">
            <a href={`/notes/${note.slug}`}>{note.data.title}</a>
            <time datetime={note.data.date.toISOString()}>
              {note.data.date.toISOString().slice(0, 10)}
            </time>
          </li>
        ))}
      </ul>
      <p class="more"><a href="/notes">all notes →</a></p>
    </section>
  )}

  <section class="block">
    <p class="section-label">projects</p>
    <ul class="list">
      <li class="list-item">
        <a href="https://github.com/mylesio/ant-protocol">ant-protocol</a>
        <span class="list-desc">multi-agent governance protocol</span>
      </li>
      <li class="list-item">
        <a href="https://github.com/mylesio/prism">prism</a>
        <span class="list-desc">AI personal profile engine</span>
      </li>
    </ul>
  </section>
</Base>

<style>
  .hero {
    padding: 3rem 0 4rem;
  }
  .hero-name {
    font-size: 1.5rem;
    font-weight: 500;
    color: #fff;
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }
  .cursor {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
    margin-left: 2px;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .hero-sub {
    color: var(--muted);
    font-size: 0.85rem;
    font-weight: 300;
  }

  .block {
    margin-bottom: 3rem;
  }

  .section-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 1rem;
  }

  .list { list-style: none; }

  .list-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
  }
  .list-item:first-child { border-top: 1px solid var(--border); }

  .list-item time,
  .list-desc {
    color: var(--muted);
    font-size: 0.78rem;
    white-space: nowrap;
    font-weight: 300;
    flex-shrink: 0;
  }

  .more {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--muted);
  }
</style>
