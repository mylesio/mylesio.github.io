---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Base title="Home">
  <section class="hero reveal reveal-2">
    <p class="hero-name">Myles Liu <span class="hero-is">is</span></p>
    <p class="hero-sub"><span id="typewriter"></span><span class="type-cursor">▌</span></p>
  </section>

  <script>
    const phrases = [
      'a frontend engineer',
      'building monitoring systems',
      'exploring AI agents',
      'writing open-source tools',
    ];
    let pi = 0, ci = 0, deleting = false;
    const el = document.getElementById('typewriter');
    if (el) {
      function tick() {
        const phrase = phrases[pi];
        if (!deleting) {
          ci++;
          el.textContent = phrase.slice(0, ci);
          if (ci === phrase.length) {
            deleting = true;
            setTimeout(tick, 1800);
            return;
          }
          setTimeout(tick, 68);
        } else {
          ci--;
          el.textContent = phrase.slice(0, ci);
          if (ci === 0) {
            deleting = false;
            pi = (pi + 1) % phrases.length;
            setTimeout(tick, 400);
            return;
          }
          setTimeout(tick, 38);
        }
      }
      setTimeout(tick, 900);
    }
  </script>

  {notes.length > 0 && (
    <section class="block reveal reveal-3">
      <p class="section-label">notes</p>
      <ul class="list">
        {notes.map((note, i) => (
          <li class="list-item" style={`--i:${i}`}>
            <a href={`/notes/${note.slug}`}>{note.data.title}</a>
            <time datetime={note.data.date.toISOString()}>
              {note.data.date.toISOString().slice(0, 10)}
            </time>
          </li>
        ))}
      </ul>
      <p class="more"><a href="/notes">all notes →</a></p>
    </section>
  )}

  <section class="block reveal reveal-4">
    <p class="section-label">projects</p>
    <ul class="list">
      <li class="list-item" style="--i:0">
        <a href="https://github.com/mylesio/ant-protocol">ant-protocol</a>
        <span class="list-desc">multi-agent governance protocol</span>
      </li>
      <li class="list-item" style="--i:1">
        <a href="https://github.com/mylesio/prism">prism</a>
        <span class="list-desc">AI personal profile engine</span>
      </li>
      <li class="list-item" style="--i:2">
        <a href="https://github.com/mylesio/mylesio.github.io">mylesio.github.io</a>
        <span class="list-desc">this site — Astro + pixel dino</span>
      </li>
      <li class="list-item" style="--i:3">
        <a href="https://github.com/mylesio/openclaw-skills">openclaw-skills</a>
        <span class="list-desc">custom skills for OpenClaw agent</span>
      </li>
      <li class="list-item" style="--i:4">
        <a href="https://github.com/mylesio/raptor-dev-workflow">raptor-dev-workflow</a>
        <span class="list-desc">full-cycle frontend dev automation</span>
      </li>
    </ul>
    <p class="more"><a href="/projects">all projects →</a></p>
  </section>
</Base>

<style>
  .hero {
    padding: 1rem 0 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5rem;
  }
  .hero-name {
    font-size: 2.4rem;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    line-height: 1.1;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .hero-is {
    color: var(--muted);
    font-size: 2.2rem;
    font-weight: 300;
    letter-spacing: -0.01em;
  }

  .hero-sub {
    color: var(--text);
    font-size: 0.92rem;
    font-weight: 300;
    letter-spacing: 0.01em;
    min-height: 1.4em;
    display: flex;
    align-items: baseline;
    gap: 1px;
    margin-top: 0.2rem;
  }

  .type-cursor {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
    margin-left: 1px;
    font-size: 0.88rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .type-cursor { animation: none; }
  }

  .block { margin-bottom: 4.5rem; }

  .section-label {
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--label);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .section-label::before {
    content: '';
    display: inline-block;
    width: 16px;
    height: 1px;
    background: var(--accent-mid);
    flex-shrink: 0;
  }

  .list { list-style: none; }

  .list-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 2rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
    opacity: 0;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.3s + var(--i, 0) * 0.07s);
  }
  .list-item:first-child { border-top: 1px solid var(--border); }

  /* link inside list — no underline, use color only */
  .list-item a {
    text-decoration: none;
    color: var(--text);
    font-weight: 400;
    border-bottom: none;
    transition: color 0.15s var(--ease-out-expo);
  }
  .list-item a:hover { color: var(--accent); }

  @media (prefers-reduced-motion: reduce) {
    .list-item { opacity: 1; animation: none; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .list-item time,
  .list-desc {
    color: var(--label);
    font-size: 0.75rem;
    white-space: nowrap;
    font-weight: 300;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }

  @media (max-width: 480px) {
    .hero { padding: 1.5rem 0 2rem; }
    .hero-name { font-size: 1.7rem; }

    .list-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }

    .list-item time,
    .list-desc {
      white-space: normal;
    }
  }

  .more {
    margin-top: 1.25rem;
    font-size: 0.78rem;
  }
  .more a {
    color: var(--muted);
    text-decoration: none;
    border-bottom: none;
    letter-spacing: 0.03em;
    transition: color 0.15s var(--ease-out-expo);
  }
  .more a:hover { color: var(--accent); }
</style>
