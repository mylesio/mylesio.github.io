---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const notes = (await getCollection('notes'))
  .filter(n => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Base title="Home">
  <section class="hero reveal reveal-2">
    <p class="hero-name">Myles Liu<span class="cursor">▌</span></p>
    <p class="hero-sub">frontend engineer · monitoring systems · AI agents</p>
  </section>

  {notes.length > 0 && (
    <section class="block reveal reveal-3">
      <p class="section-label">notes</p>
      <ul class="list">
        {notes.map((note, i) => (
          <li class="list-item" style={`--i:${i}`}>
            <a href={`/notes/${note.slug}`}>{note.data.title}</a>
            <time datetime={note.data.date.toISOString()}>
              {note.data.date.toISOString().slice(0, 10)}
            </time>
          </li>
        ))}
      </ul>
      <p class="more"><a href="/notes">all notes →</a></p>
    </section>
  )}

  <section class="block reveal reveal-4">
    <p class="section-label">projects</p>
    <ul class="list">
      <li class="list-item" style="--i:0">
        <a href="https://github.com/mylesio/ant-protocol">ant-protocol</a>
        <span class="list-desc">multi-agent governance protocol</span>
      </li>
      <li class="list-item" style="--i:1">
        <a href="https://github.com/mylesio/prism">prism</a>
        <span class="list-desc">AI personal profile engine</span>
      </li>
    </ul>
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 0 5rem;
  }
  .hero-name {
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 0.9rem;
    line-height: 1.15;
  }
  .cursor {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
    margin-left: 2px;
  }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .cursor { animation: none; }
  }

  .hero-sub {
    color: var(--muted);
    font-size: 0.88rem;
    font-weight: 300;
    letter-spacing: 0.01em;
  }

  .block { margin-bottom: 3.5rem; }

  .section-label {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--label);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .section-label::before {
    content: '';
    display: inline-block;
    width: 12px;
    height: 1px;
    background: var(--accent-dim);
    flex-shrink: 0;
  }

  .list { list-style: none; }

  .list-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.9rem;
    opacity: 0;
    animation: fadeUp 0.45s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.3s + var(--i, 0) * 0.07s);
  }
  .list-item:first-child { border-top: 1px solid var(--border); }

  @media (prefers-reduced-motion: reduce) {
    .list-item { opacity: 1; animation: none; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .list-item time,
  .list-desc {
    color: var(--muted);
    font-size: 0.78rem;
    white-space: nowrap;
    font-weight: 300;
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .hero { padding: 2.5rem 0 3.5rem; }
    .hero-name { font-size: 1.7rem; }

    .list-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.2rem;
    }

    .list-item time,
    .list-desc {
      white-space: normal;
    }
  }

  .more {
    margin-top: 1rem;
    font-size: 0.8rem;
    color: var(--muted);
  }
  .more a { border-color: transparent; color: var(--muted); }
  .more a:hover { color: var(--accent); }
</style>
