---
import Base from '../layouts/Base.astro';
---

<Base title="About" description="Myles Liu — frontend engineer, AI agent practitioner.">
  <section class="page-header">
    <h1 class="page-title">about</h1>
  </section>
  <div class="prose about-prose">
    <p>Frontend engineer at Meituan, working on monitoring infrastructure (Raptor). Based in Shanghai.</p>
    <p>On the side, I build tools around AI agents — <a href="https://github.com/mylesio/ant-protocol">ant-protocol</a> (multi-agent governance) and <a href="https://github.com/mylesio/prism">prism</a> (personal profile engine).</p>
    <p>This site is my public knowledge base. Notes on things I'm learning, systems I'm building, ideas worth writing down. It's also designed to be readable by AI agents — clean HTML, <a href="/llms.txt">llms.txt</a>, every note at its own URL.</p>

    <h2>links</h2>
    <ul>
      <li><a href="https://github.com/mylesio">github.com/mylesio</a></li>
    </ul>
  </div>
</Base>

<style>
  .page-header { padding: 2rem 0 2.5rem; }
  .page-title {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--label);
    font-weight: 400;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .page-title::before {
    content: '';
    display: inline-block;
    width: 12px;
    height: 1px;
    background: var(--accent-mid);
    flex-shrink: 0;
  }
  .about-prose { font-size: 0.9rem; }
  .about-prose p { margin-bottom: 1.35rem; line-height: 1.75; color: var(--text); }
  .about-prose a { color: var(--accent); border-color: transparent; }
  .about-prose a:hover { border-color: var(--accent); }
  .about-prose h2 {
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--label);
    font-weight: 400;
    margin: 2.5rem 0 0.85rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .about-prose h2::before {
    content: '';
    display: inline-block;
    width: 12px;
    height: 1px;
    background: var(--accent-mid);
    flex-shrink: 0;
  }
  .about-prose ul { list-style: none; }
  .about-prose li { padding: 0.35rem 0; font-size: 0.88rem; border-bottom: 1px solid var(--accent-wash); }
</style>
